# Database Configuration
# MongoDB connection string (replace with your actual MongoDB URI)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp

# Authentication
# Secret key for JWT token encryption (use a strong, random string in production)
JWT_SECRET=your_secure_random_secret_key_change_this_in_production

# Application Environment
NODE_ENV=development

# Email Reports (Mailtrap + cron)
MAILTRAP_HOST=
MAILTRAP_PORT=
MAILTRAP_USER=
MAILTRAP_PASS=
EMAIL_FROM=noreply@cottagecoins.local
EMAIL_REPORTS_CRON_SECRET=change_me_to_a_long_random_secret
APP_URL=http://localhost:3000
# Optional: set true to disable in-process cron registration
DISABLE_CRON=false

# Google Gemini (AI Forecast — server only)
GEMINI_API_KEY=
